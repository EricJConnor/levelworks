{
  "rewrites": [
    {
      "source": "/view-estimate/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|Slackbot|WhatsApp|TelegramBot|LinkedInBot|Discordbot|SkypeUriPreview|iMessage|Googlebot|bingbot|Pinterest|redditbot).*"
        }
      ],
      "destination": "/api/link-preview?type=estimate&token=:token"
    },
    {
      "source": "/view-invoice/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|Slackbot|WhatsApp|TelegramBot|LinkedInBot|Discordbot|SkypeUriPreview|iMessage|Googlebot|bingbot|Pinterest|redditbot).*"
        }
      ],
      "destination": "/api/link-preview?type=invoice&token=:token"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}